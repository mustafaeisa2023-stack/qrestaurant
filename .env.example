# ============================================================
# QRestaurant - Root Environment (Docker Compose)
# Copy to .env and fill in production values
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=qrestaurant_db
POSTGRES_USER=qrestaurant
POSTGRES_PASSWORD=change_me_in_production_use_strong_password
DB_PORT=5432

# ─── Backend ─────────────────────────────────────────────
BACKEND_PORT=4000
BACKEND_URL=https://your-domain.com

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=https://your-domain.com

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com
