# ============================================================
# QRestaurant Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── APPLICATION ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ────────────────────────────────────────────────
DATABASE_URL="postgresql://qrestaurant:password@localhost:5432/qrestaurant_db"

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── SECURITY ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# ─── UPLOADS ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads

# ─── RATE LIMITING ───────────────────────────────────────────
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=60000
THROTTLE_MEDIUM_LIMIT=100

# ─── OPTIONAL: Email (for notifications) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password

# ─── OPTIONAL: Redis (for scaling WebSockets) ─────────────────
# REDIS_URL=redis://localhost:6379
